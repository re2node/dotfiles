max-history=10
sort=-time
layer=overlay
anchor=top-right
margin=20
width=300
padding=10

font=JetBrainsMono Nerd Font 11
background-color=#282c34
text-color=#ffffff
border-size=2
border-radius=5
default-timeout=3000

on-button-left=invoke-default-action
on-button-middle=dismiss
on-button-right=none

group-by=app-name,summary,body

[urgency=low]
border-color=#8dc6f5

[urgency=high]
border-color=#bf616a
default-timeout=0
